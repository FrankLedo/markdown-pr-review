{
  "name": "markdown-pr-review",
  "displayName": "Markdown PR Review",
  "description": "Overlay GitHub PR review comments on rendered markdown previews",
  "version": "0.0.1",
  "publisher": "frankledo",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdown-pr-review.openReview",
        "title": "Open PR Review",
        "icon": "$(comment-discussion)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markdown-pr-review.openReview",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "markdown-pr-review.openReview",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "vscode:prepublish": "node esbuild.mjs --production"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "0.20.2",
    "@esbuild/darwin-x64": "^0.20.2"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/markdown-it": "^14.1.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "markdown-it": "^14.0.0",
    "mermaid": "^10.6.0",
    "typescript": "^5.3.0"
  }
}
