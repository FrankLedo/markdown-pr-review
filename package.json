{
  "name": "markdown-pr-review",
  "displayName": "Markdown PR Review",
  "description": "Read and review GitHub PR comments on rendered markdown — inline threads, Mermaid diagrams, full thread lifecycle",
  "version": "1.3.0",
  "publisher": "frankledo",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FrankLedo/markdown-pr-review.git"
  },
  "homepage": "https://github.com/FrankLedo/markdown-pr-review#readme",
  "bugs": {
    "url": "https://github.com/FrankLedo/markdown-pr-review/issues"
  },
  "license": "MIT",
  "keywords": [
    "github",
    "pull request",
    "code review",
    "markdown",
    "mermaid",
    "comments"
  ],
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdown-pr-review.openReview",
        "title": "Open PR Review",
        "icon": "$(comment-discussion)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markdown-pr-review.openReview",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "markdown-pr-review.openReview",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "vscode:prepublish": "node esbuild.mjs --production",
    "postinstall": "node -e \"const {execSync}=require('child_process'),fs=require('fs'),p='node_modules/@esbuild/darwin-x64';if(!fs.existsSync(p)){execSync('npm pack @esbuild/darwin-x64@0.20.2',{stdio:'ignore'});fs.mkdirSync(p,{recursive:true});execSync('tar -xzf esbuild-darwin-x64-0.20.2.tgz -C '+p+' --strip-components=1');fs.unlinkSync('esbuild-darwin-x64-0.20.2.tgz')}\""
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "0.20.2",
    "@esbuild/darwin-x64": "^0.20.2"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/markdown-it": "^14.1.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.20.0",
    "github-slugger": "^2.0.0",
    "markdown-it": "^14.0.0",
    "markdown-it-anchor": "^9.2.0",
    "mermaid": "^10.6.0",
    "ovsx": "^0.9.0",
    "typescript": "^5.3.0"
  }
}
